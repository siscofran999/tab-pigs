<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_whack_mole"
    tools:context=".PlayActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/img_bar_poin"
        android:layout_width="80dp"
        android:layout_height="30dp"
        android:layout_marginTop="40dp"
        android:layout_marginStart="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appbar"
        app:srcCompat="@drawable/bg_bar_poin" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/img_star_poin"
        android:layout_width="20dp"
        android:layout_height="20dp"
        app:srcCompat="@drawable/star"
        android:layout_marginStart="6dp"
        app:layout_constraintTop_toTopOf="@id/img_bar_poin"
        app:layout_constraintBottom_toBottomOf="@id/img_bar_poin"
        app:layout_constraintStart_toStartOf="@id/img_bar_poin"/>

    <TextView
        android:id="@+id/tvPoint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="1dp"
        android:textColor="@color/black"
        app:layout_constraintTop_toTopOf="@id/img_bar_poin"
        app:layout_constraintBottom_toBottomOf="@id/img_bar_poin"
        app:layout_constraintStart_toEndOf="@id/img_star_poin"
        tools:text="0"/>
    
    <TextView
        android:id="@+id/tvLevel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/value_level"
        android:textSize="20sp"
        android:textColor="#FFC107"
        android:textStyle="bold"
        android:paddingHorizontal="14dp"
        android:paddingVertical="4dp"
        android:layout_marginStart="12dp"
        android:background="@drawable/level"
        app:layout_constraintStart_toEndOf="@id/img_bar_poin"
        app:layout_constraintTop_toTopOf="@id/img_bar_poin"
        app:layout_constraintBottom_toBottomOf="@id/img_bar_poin" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressTime"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="20dp"
        app:indicatorColor="@color/red"
        app:trackColor="@color/white"
        android:progress="0"
        android:max="100"
        app:trackThickness="16dp"
        app:layout_constraintStart_toEndOf="@id/tvLevel"
        app:layout_constraintTop_toTopOf="@id/tvLevel"
        app:layout_constraintBottom_toBottomOf="@id/tvLevel" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appbar"
        tools:itemCount="3"
        tools:listitem="@layout/item_play" />

</androidx.constraintlayout.widget.ConstraintLayout>